# Gemini / Google AI
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud project (required for Cloud Run deployment)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# Google Cloud Storage (for PDF hosting / deployment)
GCS_BUCKET_NAME=your_gcs_bucket_name_here

# Optional: override default Gemini model
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
